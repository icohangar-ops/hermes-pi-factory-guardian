# Environment Configuration
# Copy this file to .env and fill in your values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_DAY_GROUP=-100xxxxxxxxx
TELEGRAM_SWING_GROUP=-100xxxxxxxxx
TELEGRAM_NIGHT_GROUP=-100xxxxxxxxx

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Email (SMTP)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Hermes Agent
HERMES_API_KEY=your_hermes_api_key_here
HERMES_MODEL=default

# Camera
CAMERA_RESOLUTION=1920x1080
CAMERA_FPS=15

# Storage
FOOTAGE_PATH=/data/footage
REPORTS_PATH=/data/reports

# GPIO Pins
VIBRATION_SPI_BUS=0
VIBRATION_SPI_CS=0
TEMP_GPIO_PIN=4
BUZZER_GPIO_PIN=23

# Factory
FACTORY_NAME=Production Line A
SHIFT_TIMEZONE=America/New_York
