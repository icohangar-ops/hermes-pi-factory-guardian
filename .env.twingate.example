# =============================================================================
# .env.twingate.example
# -----------------------------------------------------------------------------
# Append these to your existing .env (or copy this file to .env.twingate and
# reference it via `docker compose --env-file .env.twingate ...`).
#
# Generate TWINGATE_ACCESS_TOKEN / TWINGATE_REFRESH_TOKEN in the Twingate
# Admin Console: Connectors > Add Connector > Docker Compose. Tokens are
# one-time-use at creation; rotate via the API if expired.
# =============================================================================

# --- Factory identity (used by docker-compose.twingate.yml to name the
#     Connector container and the ot_net bridge). Keep these short, lowercase,
#     no spaces — they end up in container_name and network name. ---
FACTORY_NAME=factory-a
FACTORY_LINE=line-1

# --- Twingate Connector credentials (required) ---
TWINGATE_NETWORK=your-network-slug           # for <slug>.twingate.com
TWINGATE_ACCESS_TOKEN=                       # generate in Admin Console
TWINGATE_REFRESH_TOKEN=                      # generate in Admin Console

# --- Twingate Admin API key (required ONLY if you enable the event poller,
#     i.e. flip alert_routing.twingate_event_source.enabled to true in
#     config/factory_config.twingate.yaml). Generate at Settings > API. ---
TWINGATE_API_KEY=                            # required for event poller

# --- Twingate Connector options (optional, sensible defaults) ---
TWINGATE_LOG_LEVEL=3                         # 1=error .. 5=trace; 3=info
TWINGATE_LOG_ANALYTICS=v2                    # enables Network Events in container logs
TWINGATE_LABEL_HOSTNAME=                     # defaults to ${FACTORY_NAME}-${FACTORY_LINE}-pi
TWINGATE_DNS=                                # site resolver if Pi can't resolve *.factory.local

# --- Optional: Twingate Client in Linux Headless Mode (for the Pi's own
#     outbound sync). Requires a Service Account in the Admin Console. ---
# TWINGATE_CLIENT_SERVICE_ACCOUNT_KEY=

# --- Referenced by factory_config.twingate.yaml (egress allowlist + audit) ---
HERMES_SKILL_STORE_HOST=skills.hermes.local
AWS_REGION=us-east-1
SHIFT_TIMEZONE=America/New_York
